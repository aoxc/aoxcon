# =========================================================
# AOXC MONOREPO - FULL & SECURE .gitignore
# =========================================================

# --- [OS / System Noise] ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
*.swp
*.swo

# --- [Node / Package Managers] ---
# Tüm monorepo genelindeki bağımlılıklar
node_modules/
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# --- [Next.js / Frontend Frameworks] ---
# Frontend klasöründeki build ve cache dosyaları
apps/frontend/.next/
apps/frontend/out/
apps/frontend/.vercel/
.next/
out/
.vercel/
*.tsbuildinfo
next-env.d.ts

# --- [Backend / CLI Build Outputs] ---
# Derlenmiş dosyalar ve binary çıktılar
dist/
build/
bin/
obj/
publish/
lib-cov/
*.exe
*.dll
*.so
*.dylib

# --- [Secret / Environment Files] ---
# GERÇEK ŞİFRELERİ ASLA COMMIT ETME!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
!.env.example
!.env.*.example

# --- [Monorepo & Tooling Caches] ---
.turbo/
.cache/
.eslintcache
.prettiercache
.stylelintcache
.tsbuildinfo
.swc/

# --- [Logs & Debugging] ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
panic.log
debug.log

# --- [Testing & Coverage] ---
coverage/
.nyc_output/
junit.xml
__screenshots__/
.playwright/
test-results/

# --- [Blockchain / X Layer / Hardhat / Foundry] ---
# AOXC akıllı kontrat veya tool geliştiriyorsan:
artifacts/
cache/
typechain/
typechain-types/
.openzeppelin/
.forge/
out/
broadcast/

# --- [IDE / Editor Configs] ---
# Sadece ortak configleri tut, kişisel ayarları gizle
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# --- [Local Database / Storage] ---
*.db
*.sqlite
*.sqlite-journal
dump.rdb
