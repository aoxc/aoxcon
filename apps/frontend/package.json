{
  "name": "aoxc-frontend-v1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",

    "lint": "eslint .",
    "lint:fix": "eslint . --fix",

    "typecheck": "tsc --noEmit",

    "clean": "rm -rf .next node_modules",

    "prepare": "pnpm install",

    "deploy": "pnpm run build && firebase deploy",
    "deploy:hosting": "pnpm run build && firebase deploy --only hosting",

    "analyze": "NEXT_ANALYZE=true next build"
  },
  "dependencies": {
