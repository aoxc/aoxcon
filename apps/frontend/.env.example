# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: GitHub Pages sub-path publish (example: /aoxcon)
NEXT_PUBLIC_BASE_PATH=""
# Optional: set `export` for static build on GitHub Pages
NEXT_OUTPUT_MODE=""

# AOXCHAIN (primary target: aoxcore.com)
NEXT_PUBLIC_AOXCHAIN_RPC="https://rpc.aoxcore.com"
NEXT_PUBLIC_AOXCHAIN_RPC_FALLBACK="http://localhost:2626"
NEXT_PUBLIC_AOXCHAIN_API="https://api.aoxcore.com"
NEXT_PUBLIC_AOXCHAIN_CHAIN_ID="2626"

# X Layer mirror integration (AOXC token side)
NEXT_PUBLIC_XLAYER_RPC="https://rpc.xlayer.tech"
NEXT_PUBLIC_XLAYER_RPC_FALLBACK="https://xlayerrpc.okx.com"
NEXT_PUBLIC_XLAYER_API="https://api.aoxcore.com"
NEXT_PUBLIC_XLAYER_CHAIN_ID="196"

# Optional shared/demo and market settings
NEXT_PUBLIC_AOX_DEMO_API="https://api.aoxcore.com"
NEXT_PUBLIC_AOX_DEMO_CHAIN_ID="1337"
NEXT_PUBLIC_AOX_MARKET_SYMBOL="AOXCUSDT"
NEXT_PUBLIC_AOX_XLAYER_MARKET_SYMBOL="AOXCUSDT"
AOX_MARKET_SYMBOL="AOXCUSDT"
AOX_XLAYER_MARKET_SYMBOL="AOXCUSDT"
# AOX network endpoints
NEXT_PUBLIC_AOX_MAINNET_RPC="https://rpc.aoxcore.com"
NEXT_PUBLIC_AOX_MAINNET_RPC_FALLBACK="http://localhost:2626"
NEXT_PUBLIC_AOX_MAINNET_API="https://api.aoxcore.com"
NEXT_PUBLIC_AOX_MAINNET_CHAIN_ID="2626"

NEXT_PUBLIC_AOX_TESTNET_RPC="https://rpc-test.aoxcore.com"
NEXT_PUBLIC_AOX_TESTNET_RPC_FALLBACK="http://localhost:2626"
NEXT_PUBLIC_AOX_TESTNET_API="https://api-test.aoxcore.com"
NEXT_PUBLIC_AOX_TESTNET_CHAIN_ID="26260"

AOX_API_BASE_URL="https://api.aoxcore.com"
